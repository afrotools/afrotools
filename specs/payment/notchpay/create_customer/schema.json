{
  "spec_version": "1.0",
  "provider_api_version": "2024-01-01",
  "capability": "create_customer",
  "capability_type": "synchronous",
  "status": "draft",
  "currency": [
    "XAF"
  ],
  "auth": {
    "type": "api_key",
    "location": "header",
    "field": "Authorization",
    "format": "{token}",
    "env_var": "NOTCHPAY_PUBLIC_KEY"
  },
  "endpoint": {
    "method": "POST",
    "url": "https://api.notchpay.co/customers"
  },
  "example_prompt": "Create a new customer on Notch Pay with their name, email and phone number.",
  "input_schema": {
    "type": "object",
    "required": [
      "name"
    ],
    "properties": {
      "name": {
        "type": "string",
        "description": "Full name of the customer. Required."
      },
      "email": {
        "type": "string",
        "format": "email",
        "description": "Email address of the customer. Required if phone is not provided."
      },
      "phone": {
        "type": "string",
        "description": "Phone number of the customer. Required if email is not provided."
      },
      "company_name": {
        "type": "string",
        "description": "Company name of the customer."
      },
      "address": {
        "type": "object",
        "properties": {
          "street": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "postal_code": {
            "type": "string"
          }
        }
      }
    }
  },
  "response_schema": {
    "type": "object",
    "properties": {
      "status": {
        "type": "string",
        "description": "Response status label, e.g. 'Created'."
      },
      "code": {
        "type": "integer",
        "description": "HTTP status code, 201 on success."
      },
      "message": {
        "type": "string",
        "description": "Human-readable success message."
      },
      "customer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique customer identifier, e.g. 'cus.test_xxx'."
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": ["string", "null"]
          },
          "name": {
            "type": "string"
          },
          "company_name": {
            "type": ["string", "null"]
          },
          "tax_number": {
            "type": ["string", "null"]
          },
          "metadata": {
            "type": ["object", "null"]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "properties": {
      "status": {
        "type": "string"
      },
      "code": {
        "type": "integer"
      },
      "message": {
        "type": "string",
        "description": "Human-readable error description."
      }
    }
  },
  "gotchas": [
    "At least one of email or phone must be provided alongside name, even though only name is strictly required by the schema. Submitting name alone may result in a 422 validation error.",
    "The Authorization header must contain the public key directly as the token value — not prefixed with 'Bearer'. The format is exactly the key string.",
    "Customer IDs returned by Notch Pay are opaque strings. Do not apply encodeURIComponent to these IDs when constructing path-based URLs — pass them as-is."
  ]
}
